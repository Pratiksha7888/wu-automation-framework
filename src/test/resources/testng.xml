<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SDET-Demo-Suite" parallel="methods" thread-count="2" verbose="1">

    <test name="UI Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.demo.tests.LoginTest"/>
            <class name="com.demo.tests.FormTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <classes>
            <class name="com.demo.tests.APITest"/>
        </classes>
    </test>

</suite>
