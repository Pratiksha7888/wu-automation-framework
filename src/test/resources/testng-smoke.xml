<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SDET-Smoke-Suite" parallel="methods" thread-count="2" verbose="1">

    <test name="Smoke Tests Only">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.demo.tests.LoginTest"/>
            <class name="com.demo.tests.FormTest"/>
            <class name="com.demo.tests.APITest"/>
        </classes>
    </test>

</suite>
